---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog-en");

const images = import.meta.glob(
  "/src/assets/posts/**/*.{jpg,jpeg,png,webp,avif}",
  { eager: true }
);

const resolveThumbnail = (post) => {
  if (!post.data.thumbnail) return null;

  const langKey =
    `/src/assets/posts/${post.slug}/en/${post.data.thumbnail}`;

  const sharedKey =
    `/src/assets/posts/${post.slug}/${post.data.thumbnail}`;

  const module = images[langKey] ?? images[sharedKey];

  return module?.default?.src ?? null;
};
---

<BaseLayout
  lang="en"
  title="Blog | J-IMPACT"
  description="J-IMPACT technical blog."
  canonicalPath="/en/blog/"
  alternates={{ en: "/en/blog/", ja: "/ja/blog/", xDefault: "/ja/blog/" }}
  langSwitchHref="/ja/blog/"
>
  <h2>Blog</h2>

  <ul>
    {posts.map((post) => {
      const thumb = resolveThumbnail(post);
      return (
        <li>
          {thumb && (
            <img src={thumb} width="200" />
          )}
          <a href={`/en/blog/${post.slug}/`}>
            {post.data.title}
          </a>
          <p>{post.data.description}</p>
        </li>
      );
    })}
  </ul>
</BaseLayout>
