---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { resolvePostImage } from "../../../lib/resolvePostImage";

const posts = await getCollection("blog-en");

posts.sort(
  (a, b) =>
    new Date(b.data.date).getTime() -
    new Date(a.data.date).getTime()
);
---

<BaseLayout
  lang="en"
  title="Blog | J-IMPACT"
  description="J-IMPACT technical blog."
  canonicalPath="/en/blog/"
  alternates={{
    en: "/en/blog/",
    ja: "/ja/blog/",
    xDefault: "/ja/blog/"
  }}
  langSwitchHref="/ja/blog/"
>
  <h2>Blog</h2>

  <ul style="list-style:none; padding:0;">
    {posts.map((post) => {
      const imageModule =
        post.data.thumbnail
          ? resolvePostImage(
              post.slug,
              "en",
              post.data.thumbnail
            )
          : null;

      return (
        <li style="margin-bottom:3rem;">
          {imageModule && (
            <Image
              src={imageModule}
              alt={post.data.title}
              width={600}
              loading="lazy"
              format="webp"
              style="display:block; margin-bottom:0.75rem;"
            />
          )}

          <a
            href={`/en/blog/${post.slug}/`}
            style="font-size:1.3rem; font-weight:bold;"
          >
            {post.data.title}
          </a>

          <p style="margin-top:0.5rem;">
            {post.data.description}
          </p>
        </li>
      );
    })}
  </ul>
</BaseLayout>
