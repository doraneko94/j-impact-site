---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { resolvePostImage } from "../../../lib/resolvePostImage";
import { CATEGORIES } from "../../../data/categories";

const posts = await getCollection("blog-ja");

// 最新順
const sortedPosts = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 12);  // ★ 最大12件（3列×4行）

const lang = "ja";
---

<BaseLayout
  lang="ja"
  title="技術ブログ | J-IMPACT"
  description="J-IMPACTの技術ブログ一覧"
>

<section class="section container">
  <h1 class="page-title">技術ブログ</h1>

  <div class="post-grid">
    {sortedPosts.map((post) => {
      const thumbnailModule =
        post.data.thumbnail
          ? resolvePostImage(
              post.slug,
              lang,
              post.data.thumbnail
            )
          : null;

      const thumbnailUrl = thumbnailModule?.src ?? null;

      const categoryLabel =
        CATEGORIES[post.data.category]?.ja ??
        post.data.category;

      return (
        <a class="post-card" href={`/ja/blog/${post.slug}/`}>
          <div class="post-card__image">
          {thumbnailUrl && (
            <img
              src={thumbnailUrl}
              alt={post.data.title}
              loading="lazy"
            />
          )}
          </div>

          <div class="post-card__content">
            <div class="post-card__meta">
              <span class="category-badge">
                {categoryLabel}
              </span>
            </div>

            <h3 class="post-card__title">{post.data.title}</h3>
            <p class="post-card__description">{post.data.description}</p>
            <span class="read-more">続きを読む</span>
          </div>
        </a>
      );
    })}
  </div>
</section>

</BaseLayout>
