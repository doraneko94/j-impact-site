---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { CATEGORIES } from "../../data/categories";
import heroImage from "../../assets/images/hero.jpg";
import pdfBanner from "../../assets/images/pdf-banner.jpg";

// 🔥 記事取得
const posts = await getCollection("blog-ja");

const latestPosts = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// 🔥 サムネ解決
const images = import.meta.glob(
  "/src/assets/posts/**/*.{jpg,jpeg,png,webp,avif}",
  { eager: true }
);

const resolveThumbnail = (post) => {
  if (!post.data.thumbnail) return null;

  const langKey =
    `/src/assets/posts/${post.slug}/ja/${post.data.thumbnail}`;
  const sharedKey =
    `/src/assets/posts/${post.slug}/${post.data.thumbnail}`;

  const module = images[langKey] ?? images[sharedKey];
  return module?.default?.src ?? null;
};
---

<BaseLayout
  lang="ja"
  title="J-IMPACT"
  fullWidth={true}>

<!-- Hero -->
<section
  class="hero"
  style={`background-image: url(${heroImage.src});`}
>
  <div class="hero__overlay"></div>

  <div class="hero__content">
    <div class="hero__text">
      <h1><span class="accent">実装主義</span></h1>
      <p>手を動かす人のための研究所</p>
    </div>

    <div class="hero__buttons">
      <a href="/books" class="btn primary">書籍を入手する</a>
      <a href="/ja/blog" class="btn secondary">技術ブログをみる</a>
    </div>
  </div>
</section>

<div class="container">
<!-- 最新記事 -->
<section class="latest-posts container">
  <div class="section-header">
    <h2 class="section-title">最新の技術記事</h2>
    <a href="/ja/blog/" class="section-more">もっと見る →</a>
  </div>

  <div class="post-grid">
    {latestPosts.map((post) => {
      const thumb = resolveThumbnail(post);
      const categoryLabel = CATEGORIES[post.data.category]?.ja ?? post.data.category;

      return (
        <a href={`/ja/blog/${post.slug}`} class="post-card">
          <div class="post-card__image">
            {thumb && <img src={thumb} alt={post.data.title} loading="lazy" />}
          </div>
          <div class="post-card__content">
            <div class="post-card__meta">
              <span class="category-badge">{categoryLabel}</span>
            </div>

            <h3 class="post-card__title">{post.data.title}</h3>
            <p class="post-card__description">{post.data.description}</p>
            <span class="read-more">続きを読む</span>
          </div>
        </a>
      );
    })}
  </div>
</section>

<!-- PDF -->
<section 
  class="pdf-banner"
  style={`background-image: url(${pdfBanner.src});`}
>
  <div class="pdf-banner__overlay"></div>

  <div class="pdf-banner__content">
    
    <div class="pdf-banner__text">
      <h2>実践的PDF技術資料</h2>
    </div>

    <div class="pdf-banner__buttons">
      <a href="/books" class="btn primary">書籍を入手する</a>
    </div>
  </div>
</section>
</div>

</BaseLayout>
