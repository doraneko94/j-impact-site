---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

import hero from "../../assets/images/hero-dummy.jpg";
import pdfImage from "../../assets/images/pdf-dummy.jpg";
import service1 from "../../assets/images/service1-dummy.jpg";
import service2 from "../../assets/images/service2-dummy.jpg";
import service3 from "../../assets/images/service3-dummy.jpg";

// 🔥 記事取得
const posts = await getCollection("blog-ja");

// 🔥 日付降順ソート
const sortedPosts = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3); // 最新3件
---

<BaseLayout
  lang="ja"
  title="J-IMPACT | 技術を未来のインパクトへ"
  description="組込みRust・電子回路設計・信号処理を中心とした実践技術ブランド"
  canonicalPath="/ja/"
  alternates={{ ja: "/ja/", en: "/en/", xDefault: "/ja/" }}
  langSwitchHref="/en/"
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-text">
      <h1>技術力を<span>未来のインパクト</span>へ</h1>
      <p>
        組込みRust・電子回路設計・信号処理を横断する
        実装重視の技術コンテンツを提供します。
      </p>

      <div class="hero-buttons">
        <a class="btn-primary" href="/ja/blog/">ブログを見る</a>
      </div>
    </div>

    <div class="hero-image">
      <img src={hero.src} alt="J-IMPACT Hero" />
    </div>
  </section>


  <!-- 最新ブログ（自動化） -->
  <section class="section">
    <h2>最新ブログ</h2>

    <div class="card-grid">

      {sortedPosts.map((post) => (
        <div class="card">
          <h3 class="card-title">
            <a href={`/ja/blog/${post.slug}/`}>
              {post.data.title}
            </a>
          </h3>

          <p class="card-date">
            {post.data.pubDate.toISOString().split("T")[0]}
          </p>

          <p class="card-description">
            {post.data.description}
          </p>

          <a
            href={`/ja/blog/${post.slug}/`}
            class="card-link"
          >
            続きを読む →
          </a>
        </div>
      ))}

    </div>
  </section>

  <!-- Webサービス -->
  <section class="section bg-soft">
    <h2>Webサービス</h2>

    <div class="card-grid">

      <div class="card">
        <img src={service1.src} alt="Service 1" />
        <h3>PCB設計ツール</h3>
        <p>基板設計を効率化するWebアプリ。</p>
        <a href="#" class="card-link">サービスを見る →</a>
      </div>

      <div class="card">
        <img src={service2.src} alt="Service 2" />
        <h3>信号解析ビューワ</h3>
        <p>リアルタイムFFT可視化。</p>
        <a href="#" class="card-link">サービスを見る →</a>
      </div>

      <div class="card">
        <img src={service3.src} alt="Service 3" />
        <h3>回路シミュレーター</h3>
        <p>簡易SPICEシミュレーション。</p>
        <a href="#" class="card-link">サービスを見る →</a>
      </div>

    </div>
  </section>


  <!-- PDF販売 -->
  <section class="pdf-section">
    <div class="pdf-text">
      <h2>PDF技術資料</h2>
      <p>実践的な技術資料を販売しています。</p>
      <a class="btn-primary" href="#">今すぐチェック</a>
    </div>

    <div class="pdf-image">
      <img src={pdfImage.src} alt="PDF Preview" />
    </div>
  </section>


  <!-- Xフォロー -->
  <section class="section">
    <h2>XでJ-IMPACTをフォロー</h2>
    <p>最新技術情報をリアルタイムで発信しています。</p>
    <a class="btn-primary" href="#">Xをフォローする</a>
  </section>

</BaseLayout>
