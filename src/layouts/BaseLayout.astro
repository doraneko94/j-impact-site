---
import "../styles/global.css";
import { SITE, absUrl, defaultOgImagePath, type Lang } from "../lib/site";
import type { OgType } from "../lib/seo";
import flagJa from "../assets/images/flag-ja.svg";
import flagEn from "../assets/images/flag-en.svg";
import { undefined } from "astro:schema";
import GoogleAnalyticsConsent from "../components/GoogleAnalyticsConsent.astro";
import CookieConsent from "../components/CookieConsent.astro";
import "../styles/cookie-consent.css";

export type Alternates = Partial<Record<Lang, string>>;

export interface Props {
  lang: Lang;
  title: string;
  description: string;

  canonicalPath: string;
  alternates?: Alternates;

  thumbnail?: string;

  ogType?: OgType;

  // JSON-LD
  jsonLd?: unknown;

  noindex?: boolean;
}

const {
  lang,
  title,
  description,
  canonicalPath,
  alternates = {},
  thumbnail,
  ogType = "website",
  jsonLd,
  noindex = false,
} = Astro.props;

const ogImage = thumbnail ?? defaultOgImagePath(lang);
const ogImageAbs = absUrl(ogImage);

const canonical = canonicalPath
  ? absUrl(canonicalPath)
  : Astro.url.toString();

const altJa = alternates?.ja ?? null;
const altEn = alternates?.en ?? null;

const twitterSite = lang === "ja" ? SITE.twitterSites[0] : SITE.twitterSites[1];
const get_book = lang === "ja" ? "書籍を入手する" : "Get the Book";
const book = lang === "ja" ? "書籍" : "Book";
const aboutus = lang === "ja" ? "J-IMPACTについて" : "About J-IMPACT";
const blog = lang === "ja" ? "技術ブログ" : "Tech Blog";
const contact = lang === "ja" ? "お問い合わせ" : "Contact Us";
const follow = lang === "ja" ? "Xでフォローする" : "Follow on X";
const account = lang === "ja" ? "j_impact_jp" : "j_impact_en";
const x_url = `https://x.com/${account}`;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  
  <title>{title}</title>
  <meta name="description" content={description} />
  
  <link rel="canonical" href={canonical} />

  {altJa && <link rel="alternate" hreflang="ja" href={altJa} />}
  {altEn && <link rel="alternate" hreflang="en" href={altEn} />}
  {altEn && <link rel="alternate" hreflang="x-default" href={altEn} />}

  {noindex ? <meta name="robots" content="noindex,nofollow" /> : <meta name="robots" content="index,follow" />}
  
  <meta property="og:site_name" content={SITE.name} />
  <meta property="og:type" content={ogType} />
  <meta property="og:locale" content={lang === "ja" ? "ja_JP" : "en_GB"} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImageAbs} />

  <meta name="twitter:card" content="summary_large_image" />
  {twitterSite && <meta name="twitter:site" content={String(twitterSite)} />}
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageAbs} />

  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}

  <GoogleAnalyticsConsent />
</head>

<body>

<header class="navbar">
  <div class="nav-container">
    <div class="nav-logo">
      <a href={`/${lang}/`}><span class="accent">J-IMPACT</span></a>
    </div>

    <div class="nav-right">
      <div class="nav-cta">
        <a href={`/${lang}/book`} class="cta-books">{get_book}</a>
      </div>

      <!-- ハンバーガートグル -->
      <input type="checkbox" id="nav-toggle" class="nav-toggle" />
      <label for="nav-toggle" class="hamburger">
        <span></span>
        <span></span>
        <span></span>
        <div class="hamburger-label">MENU</div>
      </label>

      <nav class="nav-menu">
        <a href={`/${lang}/about`}>{aboutus}</a>
        <a href={`/${lang}/blog`}>{blog}</a>

        <div class="lang-switch">
          <a href={altJa} class="flag-link">
            <img src={flagJa.src} alt="Japanese" />
          </a>
          <a href={altEn} class="flag-link">
            <img src={flagEn.src} alt="English" />
          </a>
        </div>
      </nav>
    </div>
  </div>
</header>


<main>
  <slot />
  <CookieConsent lang={lang} />
</main>

<footer class="site-footer">
  <div class="footer-container">

    <!-- Xフォロー -->
    <div class="footer-follow">
      <a
        href={x_url}
        target="_blank"
        rel="noopener noreferrer"
        class="x-link"
      >
        <svg class="x-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor"
            d="M18.244 2H21l-6.56 7.49L22 22h-6.828l-5.35-6.99L3.75 22H1l7.06-8.06L2 2h6.93l4.86 6.36L18.244 2Zm-2.396 18h1.89L7.04 4H5.09l10.758 16Z"/>
        </svg>
        <span>{follow}</span>
      </a>
    </div>

    <!-- メインリンク -->
    <div class="footer-links">
      <a href={`/${lang}/about`}>{aboutus}</a>
      <a href={`/${lang}/blog`}>{blog}</a>
      <a href={`/${lang}/book`}>{book}</a>
      <a href={`/${lang}/contact`}>{contact}</a>
    </div>

    <!-- ポリシーリンク -->
    <div class="footer-policies">
      <a href={`/${lang}/page/terms-of-use`}>{lang === "ja" ? "ご利用条件" : "Terms of Use"}</a>
      <a href={`/${lang}/page/privacy`}>{lang === "ja" ? "プライバシー・ポリシー" : "Privacy Policy"}</a>
      <a href={`/${lang}/page/cookie`}>{lang === "ja" ? "クッキー・ポリシー" : "Cookie Policy"}</a>
      <a href="#" id="open-cookie-settings">{lang === "ja" ? "プライバシー設定" : "Privacy Settings"}</a>
    </div>

    <div class="footer-copy">
      © 2024-2026 J-IMPACT
    </div>

  </div>
</footer>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const link = document.getElementById("open-cookie-settings");
    link?.addEventListener("click", (e) => {
      e.preventDefault();
      window.JIMPACT_openCookieSettings?.();
    });
  });
</script>
</body>
</html>
