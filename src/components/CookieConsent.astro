---
import "../styles/cookie-consent.css";
const cookiePolicyPath = "/cookie";

// URLから言語判定
// const segments = Astro.url.pathname.split("/").filter(Boolean);
// const lang = segments[0] === "en" ? "en" : "ja";
const { lang } = Astro.props;

const cookie_usage = lang === "ja" ? "クッキーの利用について" : "About the Use of Cookies";
const cookie_intro1 = lang === "ja" 
  ? "本サイトでは、サイトの動作に必須のCookieに加えて、アクセス解析（Google Analytics）用のCookieを使用する場合があります。" 
  : "This website uses cookies that are necessary for its operation, and may also use analytics cookies (Google Analytics).";
  const cookie_intro2 = lang === "ja" 
  ? "解析Cookieは、同意いただいた場合のみ使用します。" 
  : "Analytics cookies are used only with your consent.";
const learn_more = lang === "ja" ? "詳細" : "Learn More";
const reject = lang === "ja" ? "拒否" : "Reject";
const settings = lang === "ja" ? "設定" : "Settings";
const accept = lang === "ja" ? "同意" : "Accept";
const cookie_settings= lang === "ja" ? "Cookie設定" : "Cookie Settings";
const close = lang === "ja" ? "閉じる" : "Close";
const essential_cookies= lang === "ja" ? "必須Cookie" : "Essential Cookies";
const cookie_required = lang === "ja" 
  ? "サイトの基本機能に必要なため、常に有効です。" 
  : "These cookies are required for the basic functionality of the website and are always active.";
const always_active = lang === "ja" ? "常に有効" : "Always active";
const analytics_cookies = lang === "ja" ? "解析Cookie（Google Analytics）" : "Analytics Cookies (Google Analytics)";
const statistical_information = lang === "ja" 
  ? "サイト改善のため、閲覧状況を匿名化・統計的に分析します。" 
  : "These cookies collect anonymised statistical information about how visitors use the website, in order to help us improve it.";
const enable_cookies = lang === "ja" ? "解析Cookieを有効にする" : "Enable analytics cookies";
const change_cookie = lang === "ja" ? "いつでも設定を変更できます。" : "You may change your cookie preferences at any time.";
const cookie_policy = lang === "ja" ? "クッキー・ポリシー" : "Cookie Policy";
---

<div id="cc-root" style="display:none">
  <!-- Banner -->
  <div id="cc-banner" class="cc-banner" role="dialog" aria-live="polite" aria-label="Cookie consent">
    <div class="cc-inner">
      <div class="cc-text">
        <div class="cc-title">{cookie_usage}</div>
        <div class="cc-desc">
          <p>{cookie_intro1}</p>
          <p>{cookie_intro2}</p>
          <a class="cc-link" href={cookiePolicyPath}>{learn_more}</a>
        </div>
      </div>
      <div class="cc-actions">
        <button id="cc-reject" class="cc-btn cc-secondary" type="button">{reject}</button>
        <button id="cc-settings" class="cc-btn cc-secondary" type="button">{settings}</button>
        <button id="cc-accept" class="cc-btn cc-primary" type="button">{accept}</button>
      </div>
    </div>
  </div>

  <!-- Modal -->
  <div id="cc-modal-backdrop" class="cc-backdrop" aria-hidden="true">
    <div id="cc-modal" class="cc-modal" role="dialog" aria-modal="true" aria-label="Cookie settings">
      <div class="cc-modal-header">
        <div class="cc-modal-title">{cookie_settings}</div>
        <button id="cc-close" class="cc-iconbtn" type="button" aria-label={close}>×</button>
      </div>

      <div class="cc-modal-body">
        <div class="cc-card">
          <div class="cc-card-row">
            <div>
              <div class="cc-card-title">{essential_cookies}</div>
              <div class="cc-card-desc">{cookie_required}</div>
            </div>
            <div class="cc-chip">{always_active}</div>
          </div>
        </div>

        <div class="cc-card">
          <div class="cc-card-row">
            <div>
              <div class="cc-card-title">{analytics_cookies}</div>
              <div class="cc-card-desc">{statistical_information}</div>
            </div>
            <label class="cc-switch" aria-label={enable_cookies}>
              <input id="cc-analytics" type="checkbox" />
              <span class="cc-slider"></span>
            </label>
          </div>
        </div>

        <div class="cc-note">
          {change_cookie}
          <a class="cc-link" href={cookiePolicyPath}>{cookie_policy}</a>
        </div>
      </div>

      <div class="cc-modal-footer">
        <button id="cc-save" class="cc-btn cc-primary" type="button">{lang === "ja" ? "保存" : "Save"}</button>
      </div>
    </div>
  </div>
</div>

<script type="module">
  import { readConsent, writeConsent } from "/js/consent.js";

  const root = document.getElementById("cc-root");
  const banner = document.getElementById("cc-banner");
  const backdrop = document.getElementById("cc-modal-backdrop");
  const analyticsToggle = document.getElementById("cc-analytics");

  const btnAccept = document.getElementById("cc-accept");
  const btnReject = document.getElementById("cc-reject");
  const btnSettings = document.getElementById("cc-settings");
  const btnClose = document.getElementById("cc-close");
  const btnSave = document.getElementById("cc-save");

  function openModal() {
    backdrop.style.display = "flex";
    backdrop.setAttribute("aria-hidden", "false");
    // set current state into toggle
    const current = readConsent();
    analyticsToggle.checked = !!current?.analytics;
    // focus management
    btnClose.focus();
    document.body.style.overflow = "hidden";
  }
  function closeModal() {
    backdrop.style.display = "none";
    backdrop.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }
  function hideBanner() {
    banner.style.display = "none";
  }

  function applyConsent(consent) {
    // Custom event so GA loader (and anything else) can react
    window.dispatchEvent(new CustomEvent("jimpact-consent-updated", { detail: consent }));
  }

  // expose for "Privacy settings" link
  window.JIMPACT_openCookieSettings = () => {
    root.style.display = "block";
    openModal();
  };

  // initial render
  root.style.display = "block";
  const existing = readConsent();

  if (!existing) {
    banner.style.display = "block";
  } else {
    banner.style.display = "none";
    // still broadcast on load so other scripts can align
    applyConsent(existing);
  }

  btnAccept.addEventListener("click", () => {
    const c = writeConsent(true);
    hideBanner();
    applyConsent(c);
  });

  btnReject.addEventListener("click", () => {
    const c = writeConsent(false);
    hideBanner();
    applyConsent(c);
  });

  btnSettings.addEventListener("click", openModal);
  btnClose.addEventListener("click", closeModal);
  backdrop.addEventListener("click", (e) => { if (e.target === backdrop) closeModal(); });

  btnSave.addEventListener("click", () => {
    const c = writeConsent(analyticsToggle.checked);
    closeModal();
    hideBanner();
    applyConsent(c);
  });

  // ESC to close modal
  window.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && backdrop.style.display === "flex") closeModal();
  });
</script>
